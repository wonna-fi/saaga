{
  "name": "@wonna/saaga",
  "version": "1.0.0-alpha.2",
  "description": "Drive a coding agent to write concise domain documentation for your codebase, then install always-on rules so agents read it before touching source.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "saaga": "dist/cli.js"
  },
  "files": [
    "dist",
    "flows",
    "prompts",
    "rules",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "documentation",
    "ai",
    "coding-agent",
    "cursor",
    "claude",
    "copilot",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wonna-fi/saaga.git"
  },
  "homepage": "https://github.com/wonna-fi/saaga#readme",
  "bugs": {
    "url": "https://github.com/wonna-fi/saaga/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "ignore": "^7.0.5",
    "picocolors": "^1.1.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.17",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.1.3"
  },
  "packageManager": "pnpm@9.15.9"
}
